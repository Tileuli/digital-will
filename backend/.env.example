# Copy this file to .env and fill in real values. Never commit .env.
# Generate strong secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# Server
PORT=5000
NODE_ENV=development

# Frontend base URL (used in email links for recipient setup/claim)
FRONTEND_URL=http://localhost:3000

# One-shot: set to "true" on next start to DROP and recreate all tables
# (use after schema changes; wipes all data). Remove or set to false after use.
DB_RESET=false

# Database
DB_HOST=localhost
DB_PORT=5433
DB_NAME=digital_will_db
DB_USER=postgres
DB_PASSWORD=CHANGEME

# JWT (use at least 64 random bytes / 128 hex chars)
JWT_SECRET=CHANGEME_generate_with_crypto_randomBytes_64
JWT_EXPIRES_IN=7d

# Check-in system
CHECKIN_INTERVAL_DAYS=7
REMINDER_HOURS_BEFORE_DUE=24

# Cron scheduler (every 5 minutes for dev; use hourly or daily in prod)
INACTIVITY_CRON=*/5 * * * *

# How long release / claim magic links remain valid (days)
RELEASE_TOKEN_TTL_DAYS=30

# Email notifications
# We support two transports — Brevo (HTTPS API) is preferred when configured,
# otherwise we fall back to a classic SMTP server via nodemailer.
#
# ── Option A: Brevo (HTTPS API) ──
# Brevo requires domain verification with DKIM/DMARC for production sending
# (consequence of the Feb 2024 Gmail/Yahoo/Microsoft sender rules — they
# reject `from: @gmail.com` even from verified single senders). Leave empty
# unless you have a custom domain.
BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=Digital Will

# ── Option B: Gmail SMTP (no domain needed, ~500 emails/day) ──
# Used when BREVO_API_KEY is empty. Setup:
#   1. Enable 2-Step Verification on the Google account
#   2. myaccount.google.com → Security → App passwords → create one
#   3. Paste the 16-character app password (no spaces) into SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=mukagali.2002.05@gmail.com
SMTP_PASS=
SMTP_FROM=mukagali.2002.05@gmail.com
