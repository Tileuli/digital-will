# Copy this file to .env and fill in real values. Never commit .env.
# Generate strong secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# Server
PORT=5000
NODE_ENV=development

# Frontend base URL (used in email links for recipient setup/claim)
FRONTEND_URL=http://localhost:3000

# One-shot: set to "true" on next start to DROP and recreate all tables
# (use after schema changes; wipes all data). Remove or set to false after use.
DB_RESET=false

# Database
DB_HOST=localhost
DB_PORT=5433
DB_NAME=digital_will_db
DB_USER=postgres
DB_PASSWORD=CHANGEME

# JWT (use at least 64 random bytes / 128 hex chars)
JWT_SECRET=CHANGEME_generate_with_crypto_randomBytes_64
JWT_EXPIRES_IN=7d

# Check-in system
CHECKIN_INTERVAL_DAYS=7
REMINDER_HOURS_BEFORE_DUE=24

# Cron scheduler (every 5 minutes for dev; use hourly or daily in prod)
INACTIVITY_CRON=*/5 * * * *

# How long release / claim magic links remain valid (days)
RELEASE_TOKEN_TTL_DAYS=30

# Email notifications
# Three transports are supported, picked in this order:
#   1. Resend if RESEND_API_KEY is set
#   2. Brevo if BREVO_API_KEY is set
#   3. SMTP via nodemailer (for local dev — Railway/Vercel/Render block outbound SMTP)
#
# ── Option 1: Resend (HTTPS API, no domain needed) ──
# Sign up at https://resend.com, copy the API key. With the default sender
# `onboarding@resend.dev` you can only send to the email registered on the
# Resend account until you verify a domain.
RESEND_API_KEY=
RESEND_FROM=Digital Will <onboarding@resend.dev>

# ── Option 2: Brevo (HTTPS API, requires a verified domain) ──
# Brevo requires DKIM/DMARC on a custom domain (Feb 2024 Gmail/Yahoo/Microsoft
# rules reject `from: @gmail.com`). Leave empty unless you own a domain.
BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=Digital Will

# ── Option 3: SMTP fallback (local dev only) ──
# Railway and most cloud hosts block outbound SMTP, so this path won't work in
# production. Fine for local dev with Mailtrap sandbox.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM=digitalwill@test.com
