# Copy this file to .env and fill in real values. Never commit .env.
# Generate strong secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# Server
PORT=5000
NODE_ENV=development

# Frontend base URL (used in email links for recipient setup/claim)
FRONTEND_URL=http://localhost:3000

# One-shot: set to "true" on next start to DROP and recreate all tables
# (use after schema changes; wipes all data). Remove or set to false after use.
DB_RESET=false

# Database
DB_HOST=localhost
DB_PORT=5433
DB_NAME=digital_will_db
DB_USER=postgres
DB_PASSWORD=CHANGEME

# JWT (use at least 64 random bytes / 128 hex chars)
JWT_SECRET=CHANGEME_generate_with_crypto_randomBytes_64
JWT_EXPIRES_IN=7d

# Check-in system
CHECKIN_INTERVAL_DAYS=7
REMINDER_HOURS_BEFORE_DUE=24

# Cron scheduler (every 5 minutes for dev; use hourly or daily in prod)
INACTIVITY_CRON=*/5 * * * *

# How long release / claim magic links remain valid (days)
RELEASE_TOKEN_TTL_DAYS=30

# Email notifications
# Preferred: Brevo (HTTPS API — works from Railway/Vercel/Render where outbound SMTP is often blocked).
# Sign up at https://brevo.com, verify a single sender email (no domain needed for the free tier),
# then create an API key under SMTP & API → API Keys and paste it below.
BREVO_API_KEY=
BREVO_FROM_EMAIL=mukagali.2002.05@gmail.com
BREVO_FROM_NAME=Digital Will

# Fallback: classic SMTP (Mailtrap sandbox locally, Postmark/SES/SendGrid in prod).
# Used only when BREVO_API_KEY is empty.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM=digitalwill@test.com
