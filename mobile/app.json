{
  "expo": {
    "name": "Digital Will",
    "slug": "digital-will-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.digitalwill.mobile"
    },
    "android": {
      "package": "com.digitalwill.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "extra": {
      "apiBaseUrl": "https://digital-will-production.up.railway.app/api"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow Digital Will to use Face ID to unlock your encrypted vault on this device."
        }
      ]
    ]
  }
}
